{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A sneaker product in the store",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the sneaker" },
        "description": { "type": "string", "description": "Detailed description" },
        "price": { "type": "number", "description": "Price in USD" },
        "images": { "type": "array", "description": "URLs of product images" },
        "category": { "type": "string", "description": "Category (e.g., Running, Lifestyle)" },
        "sizes": { "type": "array", "description": "Available US sizes" },
        "stock": { "type": "number", "description": "Available quantity" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user who placed the order" },
        "items": { "type": "array", "description": "List of items purchased" },
        "total": { "type": "number", "description": "Total order value" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "shippingAddress": { "type": "object", "description": "Delivery address" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Extended information about a user",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "Review": {
      "title": "Review",
      "description": "A customer review for a product",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "rating", "comment"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of available sneakers"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer order history"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and permissions"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product reviews"
    }
  }
}
